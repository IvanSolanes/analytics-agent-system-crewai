# But do not ignore the .gitkeep placeholders
!data/bronze/.gitkeep
!data/silver/.gitkeep
!data/gold/.gitkeep
!outputs/eda/.gitkeep
!outputs/models/.gitkeep
!outputs/predictions/.gitkeep
!outputs/reports/.gitkeep
!outputs/provenance/.gitkeep